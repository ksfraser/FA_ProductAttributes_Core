{
    "name": "ksfraser/fa-product-attributes-core",
    "description": "Business logic for FA Product Attributes - DAOs, Services, and domain models",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Kevin Fraser",
            "email": "kevin@ksfraser.com"
        }
    ],
    "require": {
        "php": ">=7.3",
        "ksfraser/ksf-modules-dao": "*",
        "ksfraser/ksf-fa-common": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5.0"
    },
    "autoload": {
        "psr-4": {
            "FrontAccounting\\ProductAttributes\\": "src/FrontAccounting/ProductAttributes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FrontAccounting\\ProductAttributes\\Test\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "scripts": {
        "test": "phpunit"
    },
    "repositories": {
        "modules-dao": {
            "type": "path",
            "url": "../ksf_ModulesDAO"
        },
        "common": {
            "type": "path",
            "url": "../ksf_FA_Common"
        }
    }
}
